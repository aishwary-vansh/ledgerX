# ─────────────────────────────────────────────
# LedgerX Backend — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=ledgerx-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — your React dev server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin seed credentials (used for initial DB seed)
ADMIN_EMAIL=admin@ledgerx.com
ADMIN_PASSWORD=Admin@1234

# Database (SQLite by default — swap to postgres in prod)
DB_TYPE=postgres
DATABASE_URL=""
